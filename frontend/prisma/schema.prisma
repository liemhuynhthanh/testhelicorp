generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Registration {
  id        Int      @id @default(autoincrement())
  fullName  String
  phone     String
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("registrations")
}

